# Prism Environment Configuration
#
# Copy this file to .env and configure as needed.
# All values have sensible defaults — override only what you need.

# ── Rendering ──
PRISM_RENDER_TARGET=canvas2d
PRISM_INITIAL_THEME=nebula
SPECTRUM_BAND_COUNT=12
MONITOR_REFRESH_RATE=60

# ── Asset Paths ──
ASSET_LOAD_PATH=./src/data
SPECTRUM_CALIBRATION_FILE=calibration.json
IDENTITY_PALETTE_FILE=colors.json
EMERGENCE_FREQUENCY_FILE=frequencies.json

# ── Diagnostics ──
SHOW_FRAME_COUNTER=false
ENABLE_PERFORMANCE_LOGGING=false
